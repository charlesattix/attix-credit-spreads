<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  EXP-1220 Paper Trading LaunchAgent for macOS.

  Runs run_exp1220.py once per weekday at 09:35 America/New_York.

  Full install instructions are in deploy/README_launchagent.md.
  Before enabling, run the smoke test manually to verify the environment.
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.pilotai.exp1220</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/env</string>
        <string>bash</string>
        <string>-lc</string>
        <string>cd /Users/charles/pilotai &amp;&amp; set -a &amp;&amp; source .env &amp;&amp; set +a &amp;&amp; /usr/bin/python3 scripts/run_exp1220.py</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/charles/pilotai</string>

    <!-- Run Mon-Fri at 9:35 AM local time -->
    <key>StartCalendarInterval</key>
    <array>
        <dict>
            <key>Weekday</key>
            <integer>1</integer>
            <key>Hour</key>
            <integer>9</integer>
            <key>Minute</key>
            <integer>35</integer>
        </dict>
        <dict>
            <key>Weekday</key>
            <integer>2</integer>
            <key>Hour</key>
            <integer>9</integer>
            <key>Minute</key>
            <integer>35</integer>
        </dict>
        <dict>
            <key>Weekday</key>
            <integer>3</integer>
            <key>Hour</key>
            <integer>9</integer>
            <key>Minute</key>
            <integer>35</integer>
        </dict>
        <dict>
            <key>Weekday</key>
            <integer>4</integer>
            <key>Hour</key>
            <integer>9</integer>
            <key>Minute</key>
            <integer>35</integer>
        </dict>
        <dict>
            <key>Weekday</key>
            <integer>5</integer>
            <key>Hour</key>
            <integer>9</integer>
            <key>Minute</key>
            <integer>35</integer>
        </dict>
    </array>

    <!-- Capture stdout/stderr to log files -->
    <key>StandardOutPath</key>
    <string>/Users/charles/pilotai/logs/exp1220_launchd.out.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/charles/pilotai/logs/exp1220_launchd.err.log</string>

    <!-- Don't run at load; only on schedule -->
    <key>RunAtLoad</key>
    <false/>

    <!-- Don't restart if it exits — we want one run per scheduled time -->
    <key>KeepAlive</key>
    <false/>

    <!-- Ensure PATH is sane for python3 -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin</string>
        <key>PYTHONUNBUFFERED</key>
        <string>1</string>
    </dict>
</dict>
</plist>
