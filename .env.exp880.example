# ============================================================================
# .env.exp880 — Environment variables for EXP-880 Crisis Hedge V2 Paper Trading
# ============================================================================
# Copy this file to .env.exp880 and fill in your actual credentials.
# NEVER commit the actual .env.exp880 file.
# ============================================================================

# Alpaca Paper Trading (create at https://app.alpaca.markets/paper/dashboard)
ALPACA_API_KEY=your_paper_api_key_here
ALPACA_API_SECRET=your_paper_api_secret_here

# Polygon.io (for options data)
POLYGON_API_KEY=your_polygon_key_here

# Telegram Alerts (optional but recommended)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Experiment identification
EXPERIMENT_ID=EXP-880
EXPERIMENT_NAME=crisis_hedge_v2_ultra_safe

# Feature flags
CRISIS_HEDGE_ENABLED=true
ENSEMBLE_ML_ENABLED=true
LEVERAGE_ENABLED=true
BASE_LEVERAGE=2.0
